{
  "version": 2,
  "installCommand": "npm install && cd client && npm install && cd ../server && npm install",
  "buildCommand": "cd client && npm run build && cd ../server && npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/analysis.ts": { "memory": 1024, "maxDuration": 60 },
    "api/analysis/export-pdf.ts": { "memory": 1024, "maxDuration": 60 },
    "api/health.ts": { "memory": 256, "maxDuration": 10 }
  }
}
